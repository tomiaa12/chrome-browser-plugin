{
  "name": "@chrome-mcp-figma-compare/mcp",
  "version": "1.0.0",
  "type": "module",
  "description": "MCP stdio server bridging Cursor/Copilot to Chrome extension via WebSocket",
  "main": "dist/server.cjs",
  "bin": {
    "chrome-mcp-figma-compare": "./dist/server.cjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node build.mjs",
    "start": "node dist/server.cjs",
    "prepublishOnly": "pnpm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomiaa12/chrome-mcp-figma-compare.git",
