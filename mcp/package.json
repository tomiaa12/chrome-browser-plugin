  "license": "MIT",
  "keywords": [
    "cursor",
    "mcp",
    "chrome",
    "figma",
    "copilot"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ws": "^8.18.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
